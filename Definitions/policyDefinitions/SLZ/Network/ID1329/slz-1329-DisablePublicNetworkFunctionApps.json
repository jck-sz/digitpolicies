{
  "$schema": "https://raw.githubusercontent.com/Azure/enterprise-azure-policy-as-code/main/Schemas/policy-definition-schema.json",
  "name": "SLZ-1329-DisablePublicNetworkFunctionApps",
  "properties": {
    "displayName": "SLZ - 1329 - Public Network Access Control for Function Apps",
        "description": "This policy ensures public network access is disabled for Azure Function Apps, by auditing or denying non-compliance.",
        "policyType": "Custom",
        "mode": "Indexed",
        "parameters": {
            "effect": {
                "type": "String",
                "metadata": {
                    "displayName": "Effect",
                    "description": "Enable or disable the execution of the policy"
                },
                "allowedValues": [
                    "Audit",
                    "Disabled",
                    "Deny"
                ],
                "defaultValue": "Audit"
            }
        },
        "policyRule": {
            "if": {
                "allOf": [
                    {
                        "field": "type",
                        "equals": "Microsoft.Web/sites"
                    },
                    {
                        "field": "kind",
                        "contains": "functionapp"
                    },
                    {
                        "anyOf": [
                            {
                                "field": "Microsoft.Web/sites/publicNetworkAccess",
                                "exists": "false"
                            },
                            {
                                "field": "Microsoft.Web/sites/publicNetworkAccess",
                                "notEquals": "Disabled"
                            }
                        ]
                    }
                ]
            },
            "then": {
                "effect": "[parameters('effect')]"
            }
        }
    }
}
