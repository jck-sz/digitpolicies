{
  "$schema": "https://raw.githubusercontent.com/Azure/enterprise-azure-policy-as-code/main/Schemas/policy-set-definition-schema.json",
  "name": "SLZ-ALZ-PolicySet",
  "properties": {
    "displayName": "SLZ - ALZ - Policy Set",
    "description": "Azure Landing Zone Policy Set for Compliance check of resource within Azure environments.",
    "metadata": {
      "category": "Monitoring",
      "version": "1.0.0"
    },
    "policyDefinitionGroups": [
      {
        "name": "Analytics"
      },
      {
        "name": "Compute"
      },
      {
        "name": "Database"
      },
      {
        "name": "Defender"
      },
      {
        "name": "General"
      },
      {
        "name": "Network"
      },
      {
        "name": "Security"
      },
      {
        "name": "Storage"
      },
      {
        "name": "Tagging"
      },
      {
        "name": "Web"
      },
      {
        "name": "Monitoring"
      },
      {
        "name": "GuestConfiguration"
      }
    ],
    "parameters": {
      // ANALYTICS
      "effect-SLZ-DenyPurviewAccounts": {
        "type": "string",
        "metadata": {
          "displayName": "Effect",
          "description": "The effect to enforce for this policy. Possible values are Audit, Deny, or Disable."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disable"
        ],
        "defaultValue": "Audit"
      },
      // COMPUTE
      "effect-SLZ-165-MachinesAuditPeriodSystemUpdatesCheck": {
        "allowedValues": [
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Audit",
        "metadata": {
          "description": "The desired effect of the policy.",
          "displayName": "Effect"
        },
        "type": "string"
      },
      "effect-SLZ-165.2-MachinesConfigurePeriodSystemUpdatesCheck": {
        "allowedValues": [
          "Audit",
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Audit",
        "metadata": {
          "description": "The desired effect of the policy.",
          "displayName": "Effect"
        },
        "type": "string"
      },
      "assessmentMode-SLZ-165.2-MachinesConfigurePeriodSystemUpdatesCheck": {
        "type": "String",
        "metadata": {
          "displayName": "Assessment mode",
          "description": "Assessment mode for the machines."
        },
        "allowedValues": [
          "ImageDefault",
          "AutomaticByPlatform"
        ],
        "defaultValue": "AutomaticByPlatform"
      },
      "osType-SLZ-165.2-MachinesConfigurePeriodSystemUpdatesCheck": {
        "type": "String",
        "metadata": {
          "displayName": "OS type",
          "description": "OS type for the machines."
        },
        "allowedValues": [
          "Windows",
          "Linux"
        ],
        "defaultValue": "Windows"
      },
      "locations-SLZ-165.2-MachinesConfigurePeriodSystemUpdatesCheck": {
        "type": "Array",
        "metadata": {
          "displayName": "Machines locations",
          "description": "The list of locations from which machines need to be targeted.",
          "strongType": "location"
        },
        "defaultValue": []
      },
      "tagValues-SLZ-165.2-MachinesConfigurePeriodSystemUpdatesCheck": {
        "type": "Object",
        "metadata": {
          "displayName": "Tags on machines",
          "description": "The list of tags that need to matched for getting target machines."
        },
        "defaultValue": {}
      },
      "tagOperator-SLZ-165.2-MachinesConfigurePeriodSystemUpdatesCheck": {
        "type": "String",
        "metadata": {
          "displayName": "Tag operator",
          "description": "Matching condition for resource tags"
        },
        "allowedValues": [
          "All",
          "Any"
        ],
        "defaultValue": "Any"
